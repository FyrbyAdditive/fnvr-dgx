# syntax=docker/dockerfile:1.7

FROM golang:1.23-alpine AS build
WORKDIR /src
COPY apps/event-processor ./apps/event-processor
RUN cd apps/event-processor && go mod tidy && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/fnvr-events ./cmd

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /out/fnvr-events /fnvr-events
ENTRYPOINT ["/fnvr-events"]
