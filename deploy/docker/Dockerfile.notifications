# syntax=docker/dockerfile:1.7

FROM golang:1.26-alpine AS build
WORKDIR /src
COPY apps/notification-dispatcher ./apps/notification-dispatcher
RUN cd apps/notification-dispatcher && go mod tidy && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/fnvr-notifications ./cmd

FROM alpine:3.23
RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /out/fnvr-notifications /fnvr-notifications
ENTRYPOINT ["/fnvr-notifications"]
