# Deploy-time secrets — COPY to `secrets.env` (gitignored) and fill with
# freshly generated values on the host. NEVER commit the real secrets.env.
#
# Generate strong values, e.g.:
#   NATS_TOKEN=$(openssl rand -hex 32)
#   MTX_PUB_PASS=$(openssl rand -hex 24)
#   FNVR_ML_SHARED_SECRET=$(openssl rand -hex 32)
# then write the derived lines below.

# NATS: the raw token (consumed by the nats server config) AND the full
# client URL with the token embedded (consumed by every service).
NATS_TOKEN=replace-me
FNVR_NATS_URL=nats://replace-me@nats:4222

# MediaMTX publish credentials. MTX_AUTHINTERNALUSERS_0_PASS overrides
# the publish user's password in mediamtx.yml; FNVR_MTX_PUBLISH_CREDS is
# the "user:pass" the pipeline's rtspclientsink URLs use to authenticate.
# The password half of both MUST be the same generated value.
MTX_AUTHINTERNALUSERS_0_PASS=replace-me
FNVR_MTX_PUBLISH_CREDS=fnvrpub:replace-me

# Shared secret the api-server presents (X-FNVR-Internal header) on
# mutating ml-worker calls; ml-worker rejects mutations without it.
FNVR_ML_SHARED_SECRET=replace-me
