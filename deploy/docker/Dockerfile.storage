# syntax=docker/dockerfile:1.7

FROM golang:1.23-alpine AS build
WORKDIR /src
COPY apps/storage-manager ./apps/storage-manager
RUN cd apps/storage-manager && go mod tidy && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/fnvr-storage ./cmd

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /out/fnvr-storage /fnvr-storage
ENTRYPOINT ["/fnvr-storage"]
